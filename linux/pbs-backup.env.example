# Two equivalent ways to set the PBS repository:
#
# 1) Single-string form (Linux native client):
#PBS_REPOSITORY=root@pam@192.168.1.100:8007:main
#
# 2) Docker-compose-style trio (backup.sh composes PBS_REPOSITORY from these,
#    matching docker-compose.yml's PBS_USER@PBS_SERVER:PBS_DATASTORE pattern):
PBS_SERVER=192.168.1.100:8007
PBS_USER=root@pam
PBS_DATASTORE=main

PBS_PASSWORD=your-password-here
PBS_FINGERPRINT=AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99

# Optional: override the PBS backup-id (default: contabo-server)
#BACKUP_ID=contabo-server
