# Proxmox Backup Server connection
PBS_SERVER=192.168.1.100:8007
PBS_USER=root@pam
PBS_PASSWORD=your-password-here
PBS_DATASTORE=main
PBS_FINGERPRINT=AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99

# Backup schedule (cron format, default: 2 AM daily)
BACKUP_CRON=0 2 * * *

# Timezone
TZ=Europe/Oslo
